CREATE TABLE counter (
    value INTEGER NOT NULL DEFAULT 0
);

initializeIfEmpty:
INSERT OR IGNORE INTO counter (rowid, value) VALUES (1, 0);

getValue:
SELECT value FROM counter WHERE rowid = 1;

increment:
UPDATE counter SET value = value + 1 WHERE rowid = 1;

decrement:
UPDATE counter SET value = value - 1 WHERE rowid = 1;

reset:
UPDATE counter SET value = 0 WHERE rowid = 1;
