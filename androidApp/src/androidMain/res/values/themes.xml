<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Amber" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.Amber.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/surface</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Amber</item>
    </style>

    <color name="surface">#FFF8F3</color>
</resources>
